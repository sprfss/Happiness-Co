# ================================
# HAPPINESS & CO — .gitignore
# ================================

# -------  Sistema operativo -------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS (por si acaso)
.DS_Store
.AppleDouble
.LSOverride

# ------- Base de datos -------
# Archivos locales de MySQL Workbench
*.mwb.bak
*.mwb~

# ------- General -------
# Archivos temporales
*.tmp
*.temp
*.log
*.bak
*.swp
*.swo

# Archivos comprimidos de entrega (el ZIP final no va al repo)
*.zip
*.rar
